<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ELSH | Sign In</title>
  <link rel="stylesheet" href="/css/user/auth.css" />
</head>
<body>

  <div class="login-wrapper">
    <div class="login-card">

      <div class="login-brand">
        <h2>ELSH</h2>
        <h3>Welcome Back</h3>
      </div>

      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form action="/login" method="POST" id="loginForm">

        <div class="form-group">
          <label>Email Address</label>
          <div class="input-wrapper <%= locals.fieldErrors?.email ? 'has-error' : '' %>">
            <input type="email" name="email" placeholder="name@example.com" value="<%= locals.formData?.email || '' %>" required />
          </div>
          <% if (locals.fieldErrors?.email) { %>
            <div class="field-error"><%= locals.fieldErrors.email %></div>
          <% } %>
        </div>

        <div class="form-group">
          <div class="password-label-row">
            <label>Password</label>
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>
          <div class="input-wrapper <%= locals.fieldErrors?.password ? 'has-error' : '' %>">
            <input type="password" name="password" id="password" placeholder="••••••••" required />
            <span class="toggle-eye" onclick="togglePass('password')">👁</span>
          </div>
          <% if (locals.fieldErrors?.password) { %>
            <div class="field-error"><%= locals.fieldErrors.password %></div>
          <% } %>
        </div>

        <button type="submit" class="btn-auth">SIGN IN</button>

      </form>

      <div class="auth-divider">
        <span>OR CONTINUE WITH</span>
      </div>

      <a href="/auth/google" onclick="window.open('/auth/google', 'googleAuth', 'width=500,height=600'); return false;" class="btn-google">
        <img src="/images/icons/user/google.png" alt="Google" />
        Google
      </a>

      <p class="auth-switch">New to ELSH? <a href="/signup">Create an account</a></p>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function togglePass(id) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
    }



    // Optional: clear form when leaving the page
    window.addEventListener('pagehide', function() {
      document.querySelectorAll('form').forEach(form => form.reset());
    });
  </script>
  <script src="/js/validation.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      if (window.ELSHValidator) {
        window.ELSHValidator.attachToForm('loginForm', ['email', 'password']);
      }
    });
  </script>

</body>
</html>