<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ELSH | Create Account</title>
  <link rel="stylesheet" href="/css/user/auth.css" />
</head>

<body>

  <%- include('../partials/navbar') %>

    <div class="auth-wrapper">
      <div class="auth-card">
        <h1>Create Account</h1>
        <p class="auth-subtitle">Join our collective of intentional living and essential luxury.</p>

        <% if (error) { %>
          <div class="auth-error">
            <%= error %>
          </div>
          <% } %>

            <form action="/signup" method="POST" id="signupForm">

              <div class="form-group">
                <label>FULL NAME</label>
                <div class="input-wrapper <%= locals.fieldErrors?.fullName ? 'has-error' : '' %>">
                  <input type="text" name="fullName" placeholder="Evelyn"
                    value="<%= locals.formData?.fullName || '' %>" />
                </div>
                <% if (locals.fieldErrors?.fullName) { %>
                  <div class="field-error">
                    <%= locals.fieldErrors.fullName %>
                  </div>
                  <% } %>
              </div>

              <div class="form-group">
                <label>EMAIL ADDRESS</label>
                <div class="input-wrapper <%= locals.fieldErrors?.email ? 'has-error' : '' %>">
                  <input type="email" name="email" placeholder="evelyn@studio.com"
                    value="<%= locals.formData?.email || '' %>" />
                </div>
                <% if (locals.fieldErrors?.email) { %>
                  <div class="field-error">
                    <%= locals.fieldErrors.email %>
                  </div>
                  <% } %>
              </div>

              <div class="form-group">
                <label>PHONE NUMBER</label>
                <div class="input-wrapper <%= locals.fieldErrors?.phone ? 'has-error' : '' %>">
                  <input type="tel" name="phone" id="phone" required pattern="[0-9]{10}" minlength="10" maxlength="10"
                    placeholder="5550000000" title="Please enter exactly 10 digits"
                    value="<%= locals.formData?.phone || '' %>" />
                </div>
                <% if (locals.fieldErrors?.phone) { %>
                  <div class="field-error">
                    <%= locals.fieldErrors.phone %>
                  </div>
                  <% } %>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>PASSWORD</label>
                  <div class="input-wrapper <%= locals.fieldErrors?.password ? 'has-error' : '' %>">
                    <input type="password" name="password" id="password" placeholder="••••••••" />
                    <span class="toggle-eye" onclick="togglePass('password')">👁</span>
                  </div>
                  <% if (locals.fieldErrors?.password) { %>
                    <div class="field-error">
                      <%= locals.fieldErrors.password %>
                    </div>
                    <% } %>
                </div>
                <div class="form-group">
                  <label>CONFIRM PASSWORD</label>
                  <div class="input-wrapper <%= locals.fieldErrors?.confirmPassword ? 'has-error' : '' %>">
                    <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••" />
                    <span class="toggle-eye" onclick="togglePass('confirmPassword')">👁</span>
                  </div>
                  <% if (locals.fieldErrors?.confirmPassword) { %>
                    <div class="field-error">
                      <%= locals.fieldErrors.confirmPassword %>
                    </div>
                    <% } %>
                </div>
              </div>

              <div class="form-checkbox">
                <input type="checkbox" id="terms" name="terms" required <%= locals.formData?.terms ? 'checked' : '' %> />
                <label for="terms">I accept the <a href="#">Terms and Conditions</a> and have read the <a
                    href="#">Privacy Policy</a>.</label>
                <% if (locals.fieldErrors?.terms) { %>
                  <div class="field-error"><%= locals.fieldErrors.terms %></div>
                <% } %>
              </div>

              <button type="submit" class="btn-auth">CREATE ACCOUNT</button>

            </form>

            <div class="auth-divider">
              <span>OR CONTINUE WITH</span>
            </div>

            <a href="/auth/google"
              onclick="window.open('/auth/google', 'googleAuth', 'width=500,height=600'); return false;"
              class="btn-google">
              <img src="/images/icons/user/google.png" alt="Google" />
              Google
            </a>

            <p class="auth-switch">Already part of the collective? <a href="/login">Sign In</a></p>

      </div>
    </div>

    <%- include('../partials/footer') %>

      <script>
        function togglePass(id) {
          const input = document.getElementById(id);
          input.type = input.type === 'password' ? 'text' : 'password';
        }


        const phoneInput = document.getElementById('phone');
        if (phoneInput) {
          phoneInput.addEventListener('input', function (e) {
            this.value = this.value.replace(/\D/g, '').slice(0, 10);
          });
        }




        window.addEventListener('pagehide', function () {
          document.querySelectorAll('form').forEach(form => form.reset());
        });
      </script>

      <script src="/js/validation.js"></script>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          if (window.ELSHValidator) {
            window.ELSHValidator.attachToForm('signupForm', ['fullName', 'email', 'phone', 'password', 'confirmPassword', 'terms']);
          }
        });
      </script>

</body>

</html>