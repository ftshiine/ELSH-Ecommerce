<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ELSH | Create Account</title>
  <link rel="stylesheet" href="/css/user/navbar.css" />
  <link rel="stylesheet" href="/css/user/auth.css" />
  <link rel="stylesheet" href="/css/user/footer.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="auth-wrapper">
    <div class="auth-card">
      <h1>Create Account</h1>
      <p class="auth-subtitle">Join our collective of intentional living and essential luxury.</p>

      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form action="/signup" method="POST" id="signupForm">

        <div class="form-row">
          <div class="form-group">
            <label>FULL NAME</label>
            <input type="text" name="fullName" placeholder="Evelyn" required />
          </div>
          <div class="form-group">
            <label>USER NAME</label>
            <input type="text" name="username" placeholder="Sterling" required />
          </div>
        </div>

        <div class="form-group">
          <label>EMAIL ADDRESS</label>
          <input type="email" name="email" placeholder="evelyn@studio.com" required />
        </div>

        <div class="form-group">
          <label>PHONE NUMBER</label>
          <input type="tel" name="phone" placeholder="+1 (555) 000-0000" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>PASSWORD</label>
            <div class="input-wrapper">
              <input type="password" name="password" id="password" placeholder="••••••••" required />
              <span class="toggle-eye" onclick="togglePass('password')">👁</span>
            </div>
          </div>
          <div class="form-group">
            <label>CONFIRM PASSWORD</label>
            <div class="input-wrapper">
              <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••" required />
              <span class="toggle-eye" onclick="togglePass('confirmPassword')">👁</span>
            </div>
          </div>
        </div>

        <div class="form-checkbox">
          <input type="checkbox" id="terms" name="terms" required />
          <label for="terms">I accept the <a href="#">Terms and Conditions</a> and have read the <a href="#">Privacy Policy</a>.</label>
        </div>

        <button type="submit" class="btn-auth">CREATE ACCOUNT</button>

      </form>

      <div class="auth-divider">
        <span>OR CONTINUE WITH</span>
      </div>

      <a href="/auth/google" class="btn-google">
        <img src="/images/icons/user/google.png" alt="Google" />
        Google
      </a>

      <p class="auth-switch">Already part of the collective? <a href="/login">Sign In</a></p>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function togglePass(id) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
    }

    // Prevent browser back button from showing cached signup page
    window.addEventListener('pageshow', function(event) {
      if (event.persisted) {
        window.location.reload();
      }
    });

    // Optional: clear form when leaving the page
    window.addEventListener('pagehide', function() {
      document.querySelectorAll('form').forEach(form => form.reset());
    });
  </script>

</body>
</html>