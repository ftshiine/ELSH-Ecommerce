<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ELSH | Ritual Sites</title>
  <link rel="stylesheet" href="/css/user/address.css" />
</head>
<body>

  <%- include('../../partials/home-navbar') %>

  <div class="address-wrapper">
    <div class="breadcrumb">
      <a href="/profile">ACCOUNT</a> &rsaquo; <span class="breadcrumb-active">RITUAL SITES</span>
    </div>

    <div class="page-header">
      <h1>Ritual Sites</h1>
      <p>Manage the sanctuaries where your ELSH essentials arrive. We ensure every delivery is handled with intentional care.</p>
    </div>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <% if (locals.success) { %>
      <div class="address-success"><%= locals.success %></div>
    <% } %>

    <% if (addresses && addresses.length > 0) { %>
      <div class="address-grid">
        <% addresses.forEach(address => { %>
          <div class="address-card">
            <div class="address-card-header">
              <h3 class="address-name"><%= address.fullName %></h3>
              <% if (address.isPrimary) { %>
                <span class="badge-primary">Primary</span>
              <% } %>
            </div>
            
            <div class="address-details">
              <%= address.addressLine1 %><br>
              <% if (address.landmark) { %>
                <%= address.landmark %><br>
              <% } %>
              <%= address.city %>, <%= address.state %> <%= address.pincode %>
              <div class="address-phone"><%= address.phone %></div>
            </div>

            <div class="address-actions">
              <a href="/profile/addresses/edit/<%= address._id %>" class="btn-action">Edit</a>
              <form action="/profile/addresses/delete/<%= address._id %>" method="POST" class="action-form" onsubmit="return confirm('Are you sure you want to remove this ritual site?');">
                <button type="submit" class="btn-action btn-delete">Remove</button>
              </form>
              <% if (!address.isPrimary) { %>
                <form action="/profile/addresses/primary/<%= address._id %>" method="POST" class="action-form primary-form">
                  <button type="submit" class="btn-action" style="color: #4a5240;">Set as Primary</button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
      <a href="/profile/addresses/add" class="btn-add-new">ADD NEW RITUAL SITE</a>
    <% } else { %>
      <div class="empty-state">
        <h3>No Ritual Sites Found</h3>
        <p>You haven't added any delivery addresses yet.</p>
        <a href="/profile/addresses/add" class="btn-add-new">ADD NEW RITUAL SITE</a>
      </div>
    <% } %>
  </div>

  <%- include('../../partials/footer') %>

</body>
</html>
