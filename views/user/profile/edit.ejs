<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ELSH | Edit Profile</title>
  <link rel="stylesheet" href="/css/user/profile.css" />
</head>

<body>

  <%- include('../partials/home-navbar') %>

    <div class="profile-wrapper">

      <div class="breadcrumb">
        <span>ACCOUNT</span>
        <span>›</span>
        <a href="/profile" class="breadcrumb-link">MY PROFILE</a>
        <span>›</span>
        <span class="breadcrumb-active">EDIT PROFILE</span>
      </div>

      <div class="edit-card">

        <div class="edit-card-header">
          <h2>Manage Profile</h2>
          <p>Update your personal information and account details.</p>
        </div>

        <div class="edit-divider"></div>

        <% if (locals.error) { %>
          <div class="auth-error">
            <%= locals.error %>
          </div>
          <% } %>
            <% if (locals.success) { %>
              <div class="auth-success">
                <%= locals.success %>
              </div>
              <% } %>

                <form id="removePhotoForm" action="/profile/photo?_method=DELETE" method="POST" style="display:none;"></form>
                <form id="changeEmailForm" action="/profile/email/initiate" method="POST" style="display:none;"></form>
                <form id="editProfileForm" action="/profile?_method=PUT" method="POST" enctype="multipart/form-data">

                  <div class="edit-section">
                    <label class="section-label">PROFILE PHOTO</label>
                    <div class="photo-upload-row">
                      <div class="edit-avatar">
                        <% if (user.profileImage) { %>
                          <img src="<%= user.profileImage %>" alt="Profile" id="avatarPreview" />
                          <% } else { %>
                            <div class="avatar-placeholder" id="avatarPlaceholder">
                              <%= user.fullName.charAt(0).toUpperCase() %>
                            </div>
                            <img src="" alt="Profile" id="avatarPreview" style="display:none;" />
                            <% } %>
                      </div>
                      <div class="photo-actions">
                        <label for="profileImage" class="btn-upload">UPLOAD NEW PHOTO</label>
                        <% if (user.profileImage) { %>
                          <button type="submit" form="removePhotoForm" class="btn-remove-photo">Remove Photo</button>
                          <% } %>

                      </div>
                    </div>
                    <div id="imageUploadError" class="field-error" style="display:none; margin-top: 0.5rem;"></div>
                  </div>

                  <div class="edit-divider"></div>

                  <div class="edit-section">
                    <label class="section-label">PERSONAL INFORMATION</label>

                    <div class="edit-form-row">
                      <div class="form-group">
                        <label>Full Name</label>
                        <div class="input-wrapper <%= locals.fieldErrors?.fullName ? 'has-error' : '' %>">
                          <input type="text" name="fullName"
                            value="<%= locals.formData?.fullName || user.fullName || '' %>" placeholder="Your full name"
                            required />
                        </div>
                        <% if (locals.fieldErrors?.fullName) { %>
                          <div class="field-error">
                            <%= locals.fieldErrors.fullName %>
                          </div>
                          <% } %>
                      </div>
                      <div class="form-group">
                        <label>Phone</label>
                        <div class="input-wrapper <%= locals.fieldErrors?.phone ? 'has-error' : '' %>">
                          <input type="tel" name="phone" value="<%= locals.formData?.phone || user.phone || '' %>"
                            placeholder="+1 (555) 000-0000" />
                        </div>
                        <% if (locals.fieldErrors?.phone) { %>
                          <div class="field-error">
                            <%= locals.fieldErrors.phone %>
                          </div>
                          <% } %>
                      </div>
                    </div>

                    <div class="edit-form-row">
                      <% if (user.googleId) { %>
                        <div class="form-group">
                          <label>Account Authentication</label>
                          <div style="font-size: 0.85rem; color: #666; margin-bottom: 0.5rem; line-height: 1.4;">
                            This account was created using Google Sign-In.<br>
                            Your email address and password are managed by your Google account and cannot be changed
                            from ELSH.
                          </div>
                          <div class="input-wrapper"
                            style="background-color: #f5f5f5; border: 1px solid #ddd; padding: 0.8rem 1rem; border-radius: 4px; display: flex; align-items: center;">
                            <span style="color: #666; font-size: 0.9rem; flex-grow: 1;">[<%= user.email %>]</span>
                          </div>
                          <input type="hidden" name="email" value="<%= user.email %>" id="emailInput"
                            data-original="<%= user.email %>" />
                        </div>
                        <% } else { %>
                          <div class="form-group">
                            <label>Email Address</label>
                            <div style="display: flex; gap: 1rem; align-items: center;">
                              <div class="input-wrapper"
                                style="background-color: #f5f5f5; border: 1px solid #ddd; padding: 0.8rem 1rem; border-radius: 4px; flex-grow: 1;">
                                <span style="color: #666; font-size: 0.9rem;">
                                  <%= user.email %>
                                </span>
                              </div>
                              <button type="submit" form="changeEmailForm" class="btn-cancel"
                                style="border-color: #556B5B; color: #556B5B; background: transparent; cursor: pointer; padding: 0.8rem 1.5rem; text-transform: uppercase; font-size: 0.8rem; font-weight: 500; transition: all 0.3s ease; white-space: nowrap; height: auto;">CHANGE</button>
                            </div>
                          </div>
                          <% } %>
                            <div class="form-group">
                              <label>Gender</label>
                              <% const selectedGender=locals.formData?.gender || user.gender || '' %>
                                <div class="input-wrapper">
                                  <select name="gender">
                                    <option value="">Select Gender</option>
                                    <option value="Male" <%=selectedGender==='Male' ? 'selected' : '' %>>Male</option>
                                    <option value="Female" <%=selectedGender==='Female' ? 'selected' : '' %>>Female
                                    </option>
                                    <option value="Other" <%=selectedGender==='Other' ? 'selected' : '' %>>Other
                                    </option>
                                    <option value="Prefer not to say" <%=selectedGender==='Prefer not to say'
                                      ? 'selected' : '' %>>Prefer not to say</option>
                                  </select>
                                </div>
                            </div>
                    </div>

                    <div class="edit-form-row">
                      <div class="form-group">
                        <label>Date of Birth</label>
                        <% const dobValue=locals.formData?.dateOfBirth || (user.dateOfBirth ? new
                          Date(user.dateOfBirth).toISOString().split('T')[0] : '' ) %>
                          <div class="input-wrapper">
                            <input type="date" name="dateOfBirth" value="<%= dobValue %>" />
                          </div>
                      </div>
                    </div>

                  </div>

                  <div class="edit-actions">
                    <a href="/profile" class="btn-cancel">CANCEL</a>
                    <button type="submit" class="btn-save">SAVE CHANGES</button>
                  </div>

                  <input type="file" id="profileImage" name="profileImage" accept="image/*" style="display:none;" />
                </form>
      </div>
    </div>

    <%- include('../partials/footer') %>

      <script>
        const profileImageInput = document.getElementById('profileImage');
        const avatarPreview = document.getElementById('avatarPreview');
        const avatarPlaceholder = document.getElementById('avatarPlaceholder');

        const imageUploadError = document.getElementById('imageUploadError');

        profileImageInput.addEventListener('change', (e) => {
          const file = e.target.files[0];
          if (file) {
            if (file.size > 5 * 1024 * 1024) {
              imageUploadError.textContent = 'Profile image is too large. Choose a different image.';
              imageUploadError.style.display = 'block';
              profileImageInput.value = '';
              return;
            }
            imageUploadError.style.display = 'none';
            const reader = new FileReader();
            reader.onload = (e) => {
              avatarPreview.src = e.target.result;
              avatarPreview.style.display = 'block';
              if (avatarPlaceholder) avatarPlaceholder.style.display = 'none';
            };
            reader.readAsDataURL(file);
          }
        });


        const editProfileForm = document.getElementById('editProfileForm');
        const submitBtn = editProfileForm.querySelector('.btn-save');
        let isSubmitting = false;

        editProfileForm.addEventListener('submit', (e) => {
          if (window.ELSHValidator && !window.ELSHValidator.validateForm(editProfileForm, ['fullName', 'phone'])) {
            e.preventDefault();
            return;
          }

          if (isSubmitting) {
            e.preventDefault();
            return;
          }
          isSubmitting = true;
          submitBtn.textContent = 'PROCESSING...';
          submitBtn.style.opacity = '0.7';
        });
      </script>
      <script src="/js/validation.js"></script>

</body>

</html>