<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ELSH | Change Password</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/user/change-password.css" />
</head>
<body>

  <%- include('../partials/home-navbar') %>

  <div class="password-wrapper">

    <div class="password-header">
      <h2>Password & Security</h2>
      <p>Update your password to keep your ELSH account secure.</p>
    </div>

    <div class="password-card">

      <div class="password-form-area">
        <h3>Update Password</h3>

        <% if (locals.error) { %>
          <div class="auth-error"><%= locals.error %></div>
        <% } %>
        <% if (locals.success) { %>
          <div class="auth-success"><%= locals.success %></div>
        <% } %>

        <form action="/profile/change-password" method="POST" id="changePasswordForm">
          <div class="form-group">
            <label>CURRENT PASSWORD</label>
            <div class="input-wrapper">
              <input type="password" name="currentPassword" id="currentPassword" placeholder="Enter current password" required />
              <i class="fa-regular fa-eye toggle-password" onclick="togglePassword('currentPassword', this)"></i>
            </div>
          </div>

          <div class="form-group">
            <label>NEW PASSWORD</label>
            <div class="input-wrapper">
              <input type="password" name="newPassword" id="newPassword" placeholder="At least 8 characters" required />
              <i class="fa-regular fa-eye toggle-password" onclick="togglePassword('newPassword', this)"></i>
            </div>
          </div>

          <div class="form-group">
            <label>CONFIRM NEW PASSWORD</label>
            <div class="input-wrapper">
              <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Repeat new password" required />
              <i class="fa-regular fa-eye toggle-password" onclick="togglePassword('confirmPassword', this)"></i>
            </div>
          </div>

          <button type="submit" class="btn-primary" id="updateBtn">UPDATE PASSWORD</button>
        </form>
        <form action="/profile/forgot-password/init" method="POST" style="margin-top: 1rem;">
          <button type="submit" class="btn-secondary">FORGOT PASSWORD</button>
        </form>
      </div>

      <div class="security-tips-area">
        <div class="security-tips">
          <div class="security-tips-title">
            <i class="fa-solid fa-shield-halved"></i> Security Tips
          </div>
          <ul>
            <li><i class="fa-regular fa-circle-check"></i> Minimum of 8 characters</li>
            <li><i class="fa-regular fa-circle-check"></i> Include uppercase and lowercase letters</li>
            <li><i class="fa-regular fa-circle-check"></i> Use numbers and special characters</li>
            <li><i class="fa-regular fa-circle-check"></i> Avoid using passwords from other accounts</li>
          </ul>
        </div>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function togglePassword(inputId, iconElement) {
      const input = document.getElementById(inputId);
      if (input.type === 'password') {
        input.type = 'text';
        iconElement.classList.remove('fa-eye');
        iconElement.classList.add('fa-eye-slash');
      } else {
        input.type = 'password';
        iconElement.classList.remove('fa-eye-slash');
        iconElement.classList.add('fa-eye');
      }
    }

    document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
      const btn = document.getElementById('updateBtn');
      if (btn.classList.contains('processing')) {
        e.preventDefault();
        return;
      }
      btn.classList.add('processing');
      btn.innerHTML = 'PROCESSING...';
    });
  </script>
</body>
</html>
