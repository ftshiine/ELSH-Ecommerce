<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin | Dashboard</title>
  <link rel="stylesheet" href="/css/admin/layout.css" />
  <link rel="stylesheet" href="/css/admin/dashboard.css" />
  <link rel="stylesheet" href="/css/admin/modal.css" />
  <style>
  body { visibility: hidden; }
</style>
</head>
<body>

  <div class="admin-layout">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/topbar') %>

      <div class="page-content">
        <div class="page-header">
          <div>
            <h1>Executive Dashboard</h1>
            <p>Welcome back. Here is what's happening with ELSH today.</p>
          </div>
          <div class="header-actions">
            <button class="btn-export">Export Report</button>
            <button class="btn-add">Add New Product</button>
          </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-label">TOTAL REVENUE</span>
            <span class="stat-value">$124,500</span>
            <span class="stat-change positive">↑ 12%</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">TOTAL ORDERS</span>
            <span class="stat-value">1,240</span>
            <span class="stat-change positive">↑ 8%</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">TOTAL PRODUCTS</span>
            <span class="stat-value">48</span>
            <span class="stat-change neutral">Low & Core</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">TOTAL CUSTOMERS</span>
            <span class="stat-value">8,920</span>
            <span class="stat-change positive">+ 243 new</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">ACTIVE COUPONS</span>
            <span class="stat-value">12</span>
            <span class="stat-change neutral">Global, Summer</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">PENDING ORDERS</span>
            <span class="stat-value">34</span>
            <span class="stat-change negative">Require Action</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">MONTHLY SALES</span>
            <span class="stat-value">$42.8k</span>
            <span class="stat-change positive">On Target</span>
          </div>
        </div>

        <!-- Revenue & Top Categories -->
        <div class="mid-grid">
          <div class="revenue-card">
            <div class="card-header">
              <h2>Revenue Overview</h2>
              <span class="dropdown">Last 30 Days ▾</span>
            </div>
            <div class="chart-placeholder">
              <p>Chart coming soon</p>
            </div>
          </div>

          <div class="categories-card">
            <div class="card-header">
              <h2>Top Categories</h2>
              <span>⋮</span>
            </div>
            <div class="category-item">
              <span>Face Cleansers</span>
              <div class="progress-bar">
                <div class="progress" style="width: 45%"></div>
              </div>
              <span>45%</span>
            </div>
            <div class="category-item">
              <span>Serums</span>
              <div class="progress-bar">
                <div class="progress" style="width: 32%"></div>
              </div>
              <span>32%</span>
            </div>
            <div class="category-item">
              <span>Moisturizers</span>
              <div class="progress-bar">
                <div class="progress" style="width: 23%"></div>
              </div>
              <span>23%</span>
            </div>
            <div class="bestseller-note">
              "Hydrating Gentle Cleanser" is your current best-seller this month.
            </div>
          </div>
        </div>

        <!-- Recent Orders & Low Stock -->
        <div class="bottom-grid">
          <div class="orders-card">
            <div class="card-header">
              <h2>Recent Orders</h2>
              <a href="/admin/orders">View All Orders</a>
            </div>
            <table class="orders-table">
              <thead>
                <tr>
                  <th>ORDER</th>
                  <th>CUSTOMER</th>
                  <th>PRODUCT</th>
                  <th>STATUS</th>
                  <th>TOTAL</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>#LM-9021</td>
                  <td>Elena S.</td>
                  <td>ELSH Serum</td>
                  <td><span class="badge shipped">Shipped</span></td>
                  <td>$124.00</td>
                </tr>
                <tr>
                  <td>#LM-9020</td>
                  <td>Marcus K.</td>
                  <td>Face Cleanser Duo</td>
                  <td><span class="badge processing">Processing</span></td>
                  <td>$89.50</td>
                </tr>
                <tr>
                  <td>#LM-9019</td>
                  <td>Chloe B.</td>
                  <td>Night Recovery Cream</td>
                  <td><span class="badge pending">Pending</span></td>
                  <td>$210.00</td>
                </tr>
                <tr>
                  <td>#LM-9018</td>
                  <td>Julian D.</td>
                  <td>Rose Water Toner</td>
                  <td><span class="badge shipped">Shipped</span></td>
                  <td>$45.00</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="lowstock-card">
            <div class="card-header">
              <h2>⚠ Low Stock</h2>
            </div>
            <div class="stock-item">
              <span>Lip Balms</span>
              <span class="stock-warning">Only 4 left</span>
            </div>
            <div class="stock-item">
              <span>Nose Strips</span>
              <span class="stock-warning">Only 10 left</span>
            </div>
            <div class="stock-item">
              <span>Travel Mist</span>
              <span class="stock-warning">8 left</span>
            </div>
            <button class="btn-inventory">Inventory Report</button>
          </div>
        </div>

      </div>

      <div class="page-footer">
        <span>© 2024 ELSH Skincare Admin Panel</span>
        <div class="footer-links">
          <a href="#">Support</a>
          <a href="#">Docs</a>
          <a href="#">System Status</a>
        </div>
      </div>
    </div>
  </div>

<script>
  // Disable bfcache completely
  window.addEventListener('unload', () => {});

  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      window.location.replace('/admin/login');
    } else {
      document.body.style.visibility = 'visible';
    }
  });
</script>

</body>
</html>