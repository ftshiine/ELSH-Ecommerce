<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin | Login</title>
  <link rel="stylesheet" href="/css/admin/auth/login.css" />
</head>
<body>


  <div class="wrapper">
    <div class="card">
      <h1>Welcome Back</h1>
      <p>Please enter your credentials to access the dashboard.</p>

      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <form action="/admin/login" method="POST">
        <div class="form-group">
          <label>EMAIL ADDRESS</label>
          <div class="input-wrapper">
            <input type="email" name="email" placeholder="admin@elsh.com" required />
            <span class="icon">✉</span>
          </div>
        </div>

        <div class="form-group">
          <div class="password-label-row">
            <label>PASSWORD</label>
            <a href="/admin/forgot-password" class="forgot-link">FORGOT PASSWORD?</a>
          </div>
          <div class="input-wrapper">
            <input type="password" name="password" id="passwordInput" placeholder="••••••••" required />
            <span class="icon" onclick="togglePassword()">👁</span>
          </div>
        </div>

        <button type="submit" class="btn-login">SIGN IN TO ELSH</button>
      </form>

      <div class="card-footer">
        <span>© 2024 ELSH Admin Portal</span>
        <div class="links">
          <a href="#">SECURITY</a>
          <a href="#">SUPPORT</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    function togglePassword() {
      const input = document.getElementById('passwordInput');
      input.type = input.type === 'password' ? 'text' : 'password';
    }
  </script>

</body>
</html>