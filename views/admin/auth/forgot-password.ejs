<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin | Recover Password</title>
  <link rel="stylesheet" href="/css/user/forgot-password.css" />
</head>
<body>

  <div class="recovery-wrapper">
    <div class="recovery-card">
      
      <div class="recovery-image-side">
        <div class="glass-logo">
          <h1>ELSH</h1>
          <p>Admin Portal Recovery</p>
        </div>
      </div>

      <div class="recovery-form-side">
        <h2>Recover Access</h2>
        <p>Enter your administrator email to receive a recovery code.</p>

        <% if (error) { %>
          <div class="auth-error"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="auth-success"><%= success %></div>
        <% } %>

        <form action="/admin/forgot-password" method="POST" id="forgotForm">
          <div class="form-group">
            <label>Admin Email</label>
            <div class="input-wrapper">
              <input type="email" name="email" placeholder="admin@elsh.com" required />
              <span class="icon">@</span>
            </div>
          </div>

          <button type="submit" class="btn-primary">
            SEND CODE <span>→</span>
          </button>
        </form>

        <div class="divider"></div>

        <a href="/admin/login" class="back-link">
          <span>←</span> Back to Login
        </a>
      </div>

    </div>
  </div>

  <div style="text-align: center; padding: 1rem; color: #999; font-size: 0.8rem;">
    © 2024 ELSH Admin Portal
  </div>

  <script>
    document.getElementById('forgotForm').addEventListener('submit', function(e) {
      const btn = this.querySelector('button[type="submit"]');
      if (btn.classList.contains('processing')) {
        e.preventDefault();
        return;
      }
      btn.classList.add('processing');
      btn.innerHTML = 'PROCESSING...';
      btn.style.opacity = '0.7';
      btn.style.cursor = 'not-allowed';
    });
  </script>
  <script src="/js/validation.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      if (window.ELSHValidator) {
        window.ELSHValidator.attachToForm('forgotForm', ['email']);
      }
    });
  </script>

</body>
</html>
