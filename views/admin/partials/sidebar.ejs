<!-- Logout Modal -->
<div class="modal-overlay" id="logoutModal">
  <div class="modal-box">
    <div class="modal-icon">
      <img src="/images/icons/admin/logout.svg" alt="Logout" />
    </div>
    <h2 class="modal-title">Leaving so soon?</h2>
    <p class="modal-message">Are you sure you want to logout of the ELSH Admin Panel?</p>
    <div class="modal-actions">
      <button class="modal-btn modal-btn-cancel" id="cancelLogout">Stay</button>
      <a href="/admin/logout" class="modal-btn modal-btn-confirm">Yes, Logout</a>
    </div>
  </div>
</div>